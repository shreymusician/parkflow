# ─────────────────────────────────────────────────────────────
# ParkFlow Frontend — Environment Variables
#
# These values are embedded at BUILD TIME by Vite.
# Change them to match your machine's LAN IP if you want
# to test from a phone / tablet on the same Wi-Fi network.
#
# Your current Wi-Fi IP: 192.168.31.56
# ─────────────────────────────────────────────────────────────

# Backend REST API base URL
VITE_API_URL=http://192.168.31.56:5000/api/v1

# Backend Socket.IO server URL  (no path — just host:port)
VITE_SOCKET_URL=http://192.168.31.56:5000
