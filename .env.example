# API Configuration
# Point this to your backend production URL (e.g., https://your-backend.onrender.com/api/v1)
# DO NOT use localhost or 192.168.x.x in production
VITE_API_URL=https://your-backend.onrender.com/api/v1

# Socket.IO Configuration
# Point this to your backend production domain (without /api/v1)
VITE_SOCKET_URL=https://your-backend.onrender.com
