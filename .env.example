# ─────────────────────────────────────────────────────────────
# ParkFlow Frontend — Environment Variables EXAMPLE
#
# Copy this file to .env and fill in your actual values.
# ─────────────────────────────────────────────────────────────

# For localhost-only development (default):
VITE_API_URL=http://localhost:5000/api/v1
VITE_SOCKET_URL=http://localhost:5000

# For LAN / mobile testing (replace with your PC's Wi-Fi IP):
# VITE_API_URL=http://192.168.x.x:5000/api/v1
# VITE_SOCKET_URL=http://192.168.x.x:5000
