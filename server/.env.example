# Database
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxx.mongodb.net/smart-parking

# Authentication
JWT_SECRET=your_secure_jwt_secret_here

# Server
PORT=5000

# Allowed frontend origins (comma-separated)
# Add your machine's LAN IP so mobile devices on the same Wi-Fi can connect.
# Example: CLIENT_URL=http://localhost:5173,http://192.168.1.100:5173
CLIENT_URL=http://localhost:5173
